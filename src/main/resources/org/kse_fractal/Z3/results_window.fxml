<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx" spacing="10" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.kse_fractal.Z3.ResultsWindowController"
      prefHeight="400.0" prefWidth="600.0" styleClass="results_window">

    <HBox fx:id="root_box" spacing="5" alignment="TOP_CENTER">
        <VBox alignment="CENTER_LEFT">
            <CheckBox fx:id="allBox" onAction="#renderDataTableContainer" text="Показать пеерменные, используемые при счёте (дебаг)" />
        </VBox>
        <HBox HBox.hgrow="ALWAYS"/>
        <HBox spacing="8">
            <Button onAction="#exportJson">Экспорт в .json</Button>
            <Button text="Визуализация" disable="true" />
        </HBox>
    </HBox>

    <VBox prefWidth="Infinity" spacing="20">
        <ListView fx:id="container" />
    </VBox>
</VBox>
